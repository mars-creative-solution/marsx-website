# Copy this file to .env.local and fill in real values.
# Hostinger SMTP credentials for the contact form (app/api/contact/route.ts).

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@marsx.ae
SMTP_PASSWORD=

# Recipient for contact form submissions.
CONTACT_TO_EMAIL=info@marsx.ae

# Optional: display name used in the "From" header (the address is always SMTP_USER).
CONTACT_FROM_NAME=MarsX Website
